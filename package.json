{
  "name": "weixin-local-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build --config vite.config.mts",
    "typecheck:web": "vue-tsc --noEmit -p public/tsconfig.json",
    "build": "npm run clean && npm run build:server && npm run build:web",
    "start": "node dist/index.js",
    "dev:web": "vite --config vite.config.mts"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "typescript": "^5.8.0",
    "vite": "^6.4.1",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.4",
    "silk-wasm": "^3.7.1",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  }
}
